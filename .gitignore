# Gradle build directories (anchored to root and app module — never match source packages)
.gradle/
app/build/
*.class

# Local configuration — contains SDK path, never commit
local.properties

# Log / OS files
*.log
.DS_Store
Thumbs.db

# Android Studio / IntelliJ
.idea/
*.iml
captures/
.externalNativeBuild/
.cxx/
misc.xml
deploymentTargetDropDown.xml
render.experimental.xml

# Build outputs — exclude Gradle intermediate APKs but allow build/mopio-debug.apk
output-metadata.json

# Keystore files — never commit signing keys
*.jks
*.keystore

# Google services
google-services.json

# Profiling
*.hprof

# Native library binaries are binary blobs; commit only the README placeholder.
# Obtain all three via: ./scripts/get_proot.sh
app/src/main/jniLibs/arm64-v8a/libproot.so
app/src/main/jniLibs/arm64-v8a/libtalloc.so
app/src/main/jniLibs/arm64-v8a/libandroid-shmem.so
